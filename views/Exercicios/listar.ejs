<script src="/js/Exercicios/listar.js"></script>
<script src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>

<h1>Exercícios</h1>
<div>
    <div class="form-group">
        <label>Busca de exercícios:</label>
        <input type="text" id="txtBusca" class="form-control" placeholder="Digite aqui">
    </div>
    <div>
        <input type="checkbox" id="id" name="id" checked><label for="id">Id</label>
        <input type="checkbox" id="nome" name="nome" checked><label for="nome">Nome</label>
        <input type="checkbox" id="musculo" name="musculo" checked><label for="musculo">Músculo</label>
        <button id="btnBuscar" class="btn btn-primary"><i class="fas fa-search"></i> Buscar</button>
        <button id="sheetjsexport" class="btn btn-success"><i class="fas fa-file-excel"></i> Exportar para Excel</button>
    </div>
    <br>
    <div class="table-responsive">
        <table id="tabela" class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome do Exercício</th>
                    <th>Músculo</th>
                    <th>Imagem</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% for(let i = 0; i < listaExercicios.length; i++) { %>
                    <tr>
                        <td><%= listaExercicios[i].exe_id %></td>
                        <td><%= listaExercicios[i].exe_nome %></td>
                        <td><%= listaExercicios[i].exe_musculo %></td>
                        <td>
                            <div class="dropdown">
                                <button class="btn btn-light dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"><i class="fas fa-eye"></i></button>
                                <div class="dropdown-menu" aria-labelledby="dropdownMenuButton"><img class="dropdown-item" width="20" src="<%= listaExercicios[i].exe_imagem %>"/></div>
                            </div>
                        </td>
                        <td>
                            <div>
                                <button data-id="<%= listaExercicios[i].exe_id %>" title="Excluir" class="btn btn-danger btnExcluir"><i class="fas fa-trash"></i></button>
                                <a href="/Exercicios/alterar/<%= listaExercicios[i].exe_id %>" title="Alterar" class="btn btn-secondary"><i class="fas fa-pen"></i></a>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>