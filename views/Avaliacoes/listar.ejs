<script src="/js/Avaliacoes/listar.js"></script>
<script src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>

<h1>Avaliacoes</h1>
<div>
    <div class="form-group">
        <label>Busca de avaliacoes:</label>
        <input type="text" id="txtBusca" class="form-control" placeholder="Digite aqui">
    </div>
    <div>
        <input type="checkbox" id="id" name="id" checked><label for="id">Id</label>
        <input type="checkbox" id="cpf" name="cpf" checked><label for="cpf">CPF</label>
        <input type="checkbox" id="nome" name="nome" checked><label for="nome">Data</label>
        <button id="btnBuscar" class="btn btn-primary"><i class="fas fa-search"></i> Buscar</button>
        <button id="sheetjsexport" class="btn btn-success"><i class="fas fa-file-excel"></i> Exportar para Excel</button>
    </div>
    <br>
    <div class="table-responsive">
        <table id="tabela" class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>CPF do Assinante</th>
                    <th>Data</th>
                    <th>Documento</th>
                </tr>
            </thead>
            <tbody>
                <% for(let i = 0; i < listaAvaliacoes.length; i++) { %>
                    <tr>
                        <td><%= listaAvaliacoes[i].ava_id %></td>
                        <td><%= listaAvaliacoes[i].ass_cpf %></td>
                        <td><%= listaAvaliacoes[i].ava_data %></td>
                        <td><a href="<%= listaAvaliacoes[i].ava_pdf %>" download><i class="fas fa-download"></i></a></td>
                        <td>
                            <div>
                                <button data-id="<%= listaAvaliacoes[i].ava_id %>" title="Excluir" class="btn btn-danger btnExcluir"><i class="fas fa-trash"></i></button>
                                <a href="/Avaliacoes/alterar/<%= listaAvaliacoes[i].ava_id %>" title="Alterar" class="btn btn-secondary"><i class="fas fa-pen"></i></a>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>