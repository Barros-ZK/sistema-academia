<script src="/js/Assinantes/listar.js"></script>
<script src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>

<h1>Assinantes</h1>
<div>
    <div class="form-group">
        <label>Busca de assinantes:</label>
        <input type="text" id="txtBusca" class="form-control" placeholder="Digite aqui">
    </div>
    <div>
        <input type="checkbox" id="cpf" name="cpf" checked><label for="cpf">CPF</label>
        <input type="checkbox" id="nome" name="nome" checked><label for="nome">Nome</label>
        <input type="checkbox" id="telefone" name="telefone" checked><label for="telefone">Telefone</label>
        <button id="btnBuscar" class="btn btn-primary"><i class="fas fa-search"></i> Buscar</button>
        <button id="sheetjsexport" class="btn btn-success"><i class="fas fa-file-excel"></i> Exportar para Excel</button>
    </div>
    <br>
    <div class="table-responsive">
        <table id="tabela" class="table table-striped">
            <thead>
                <tr>
                    <th>CPF</th>
                    <th>Nome</th>
                    <th>Telefone</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% for(let i = 0; i < listaAssinantes.length; i++) { %>
                    <tr>
                        <td><%= listaAssinantes[i].ass_cpf %></td>
                        <td><%= listaAssinantes[i].ass_nome %></td>
                        <td><%= listaAssinantes[i].ass_telefone %></td>
                        <td>
                            <div>
                                <button data-cpf="<%= listaAssinantes[i].ass_cpf %>" title="Excluir" class="btn btn-danger btnExcluir"><i class="fas fa-trash"></i></button>
                                <a href="/assinantes/alterar/<%= listaAssinantes[i].ass_cpf %>" title="Alterar" class="btn btn-secondary"><i class="fas fa-pen"></i></a>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>